# ---------------------------------------------------------------------------
# Vylora X Portal — environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# PostgreSQL connection string used by the app at runtime.
# - Neon:     postgresql://user:pass@ep-xxx.eu-west-2.aws.neon.tech/db?sslmode=require
# - Supabase: use the POOLED (PgBouncer, port 6543) URI and add ?pgbouncer=true
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vylorax?schema=public"

# Direct (non-pooled) connection used only for migrations / schema changes.
# - Neon:     same value as DATABASE_URL is fine.
# - Supabase: use the DIRECT (port 5432) URI.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/vylorax?schema=public"

# Auth.js (NextAuth v5) secret — generate one with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-long-random-string"

# Public base URL of the portal. Used to build the embed snippet shown in admin.
# Local: http://localhost:3000   Production: https://portal.vylorax.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Server-side secret used to salt the daily-rotating visitor hash.
# This + the date produces the rotating salt so visitors are countable per-day
# but never personally identifiable. Generate with: openssl rand -base64 32
VISITOR_ID_SECRET="replace-me-with-another-long-random-string"

# Optional: absolute or relative path to a MaxMind GeoLite2-City .mmdb file.
# If unset, the app looks for ./geo/GeoLite2-City.mmdb. If neither exists,
# geo-lookup is skipped gracefully (country/city stored as null).
# GEOLITE2_DB_PATH="./geo/GeoLite2-City.mmdb"
